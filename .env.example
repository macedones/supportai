# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env (ele ja esta no .gitignore).

# Provedor de IA usado para embeddings e geracao de respostas:
#   openai (padrao) - usa a API da OpenAI. Requer OPENAI_API_KEY
#                      com billing ativo (platform.openai.com).
#   mock            - nao faz nenhuma chamada externa, zero custo.
#                      Util para desenvolvimento/testes/onboarding.
#                      Embeddings via feature hashing, resposta
#                      simulada mostrando os trechos recuperados.
AI_PROVIDER=openai

# Chave da API da OpenAI (platform.openai.com -> API Keys)
# Obrigatorio apenas se AI_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Conexao com o Postgres (valores correspondem ao docker-compose.yml)
DATABASE_URL=postgresql://supportai:supportai_dev@localhost:5432/supportai
