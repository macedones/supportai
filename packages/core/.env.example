# Copie para .env (packages/core) ou .env.local (apps/api) e preencha.
# NUNCA commite arquivos .env reais.

# ------------------------------------------------------------
# PROVEDOR DE IA — escolha um dos quatro abaixo
# ------------------------------------------------------------

# OPCAO 1: Groq (chat gratuito) + Ollama local (embeddings)
# - Crie conta gratuita em console.groq.com para obter a chave
# - Instale Ollama (ollama.com) e rode: ollama pull nomic-embed-text
AI_PROVIDER=groq
GROQ_API_KEY=gsk_...
OLLAMA_URL=http://localhost:11434

# OPCAO 2: Ollama local (chat + embeddings, zero dependencia externa)
# - Instale Ollama e rode: ollama pull nomic-embed-text && ollama pull llama3.2
# AI_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434

# OPCAO 3: OpenAI (melhor qualidade, requer billing)
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# OPCAO 4: Mock (sem chamadas externas, para CI e onboarding)
# AI_PROVIDER=mock

# ------------------------------------------------------------
# BANCO DE DADOS
# ------------------------------------------------------------
# Valores correspondem ao docker-compose.yml — nao alterar para dev local
DATABASE_URL=postgresql://supportai:supportai_dev@localhost:5432/supportai
